{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "strict": ["error", "global"],
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "warn"
  }
}
