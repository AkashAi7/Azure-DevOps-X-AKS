# =============================================================================
# workshop.env
# Fortis Workshop - Shared configuration file
#
# The admin fills this in ONCE after running provision-infra and distributes
# it to all participants.  Participant scripts (participant-setup.ps1 / .sh / .py)
# read these values automatically — no manual editing of individual scripts needed.
#
# HOW TO USE:
#   1. Admin: fill in every value below after completing lab-00-admin-setup
#   2. Admin: share this file with all participants (email, Teams, USB, etc.)
#   3. Participant: place this file in the repo root (next to README.md)
#   4. Participant: run the setup script — it picks up values from here
# =============================================================================

# --- Azure Subscription ---
AZURE_SUBSCRIPTION_ID=

# --- AKS ---
AKS_RESOURCE_GROUP=rg-workshop-aks
AKS_CLUSTER_NAME=aks-workshop-01

# --- ACR ---
ACR_NAME=workshopacr01

# --- Azure DevOps ---
AZDO_ORG=https://dev.azure.com/<your-org>
AZDO_PROJECT=workshop-project
AZDO_CLONE_URL=
